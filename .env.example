# ==========================================
# 📅 Slot Booking & Offer Management System
# Root Environment Variables Configuration Example
# ==========================================

# ------------------------------------------
# 🖥️ FRONTEND CONFIGURATION (React + Vite)
# ------------------------------------------
# The port on which the Frontend local dev server will run
VITE_PORT=3000

# The target API URL where the Backend is hosting the Swagger API
# (During local development, requests to /api are proxied here)
VITE_API_URL=http://localhost:5171


# ------------------------------------------
# ⚙️ BACKEND CONFIGURATION (.NET Web API)
# ------------------------------------------
# ASP.NET Core environment state (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Port/URL bindings for the backend web server
ASPNETCORE_URLS=http://localhost:5171

# Entity Framework Database Connection String (SQLite Default)
ConnectionStrings__DefaultConnection="Data Source=SlotBooking.db"

# JSON Web Token (JWT) Security Config
Jwt__Key="YOUR_SUPER_SECRET_JWT_KEY_MINIMUM_32_CHARACTERS"
Jwt__Issuer="SlotBookingAPI"
Jwt__Audience="SlotBookingApp"
